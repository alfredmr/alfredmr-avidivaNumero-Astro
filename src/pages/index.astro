---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Guess the Number">
    <div class="secreto-display" id="secretoDisplay">
        <div class="secreto-label" data-i18n="secretEncrypted" id="secretoLabel">◈ Encrypted code ◈</div>
        <div class="secreto-numero encriptado" id="displaySecreto">???</div>
    </div>

    <div class="card">
        <h1 data-i18n="heading">GUESS THE NUMBER</h1>
        <p class="subtitle" data-i18n="subtitle">Guessing system v2.0</p>

        <div id="pasoConfiguracion">
            <p class="desc" data-i18n="configDesc">
                Choose how the secret number is generated (from <strong>1 to 10</strong>):
            </p>

            <div class="modo-selector">
                <button type="button" class="modo-btn activo" id="btnModoManual" data-i18n="modeManual">🧠 I choose</button>
                <button type="button" class="modo-btn" id="btnModoAleatorio" data-i18n="modeRandom">🎲 Random</button>
            </div>

            <div id="bloqueManual">
                <p class="desc" data-i18n="manualDesc">Think of a number and enter it. Nobody should see it.</p>
                <div class="input-group">
                    <input type="number" id="numeroPensado" min="1" max="10" placeholder="?" />
                </div>
            </div>

            <div id="bloqueAleatorio" class="oculto">
                <div class="modo-aleatorio-info" data-i18n="randomInfo">
                    The system will pick a random number between <span>1</span> and <span>10</span>.<br />
                    You won't see it until you win or lose!
                </div>
            </div>

            <button type="button" class="btn btn-primary" id="btnIniciar" data-i18n="btnStart">▶ Start mission</button>
            <p id="mensajeConfig"></p>
        </div>

        <div id="pasoJuego" class="oculto">
            <p class="desc" data-i18n="gameDesc">Guess the code! You have <strong>3 attempts</strong>.</p>

            <div class="intentos-bar">
                <div class="intento-dot" id="dot1"></div>
                <div class="intento-dot" id="dot2"></div>
                <div class="intento-dot" id="dot3"></div>
            </div>

            <div class="input-group">
                <input type="number" id="intentoUsuario" min="1" max="10" placeholder="?" />
                <button type="button" class="btn btn-guess" id="btnGuess">⚡</button>
            </div>

            <p id="mensajePistas"></p>

            <div id="resultadoFinal" class="oculto">
                <span data-i18n="resultPrefix">The code was: </span><span id="numeroOculto"></span>
            </div>

            <button type="button" class="btn btn-restart oculto" id="btnReiniciar" data-i18n="btnRestart">↺ Restart game</button>
        </div>
    </div>

    <script>
        import '../scripts/game.ts';
    </script>
</Layout>
