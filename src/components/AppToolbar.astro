<div class="app-toolbar" role="toolbar" aria-label="Preferences">
    <div class="toolbar-group" aria-label="Language">
        <button
            type="button"
            class="toolbar-btn lang-btn"
            id="btnLangEn"
            data-locale="en"
            aria-label="English"
        >EN</button>
        <button
            type="button"
            class="toolbar-btn lang-btn"
            id="btnLangEs"
            data-locale="es"
            aria-label="Español"
        >ES</button>
    </div>
    <button
        type="button"
        class="toolbar-btn theme-btn"
        id="btnThemeToggle"
        aria-label="Toggle theme"
    >
        <span class="theme-icon theme-icon-light" aria-hidden="true">☀</span>
        <span class="theme-icon theme-icon-dark" aria-hidden="true">☽</span>
    </button>
</div>
